{
  "version": 2,
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/(assets|uploads)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/admin/login.php",
      "dest": "/api/login.php"
    },
    {
      "src": "/admin/logout.php",
      "dest": "/api/logout.php"
    },
    {
      "src": "/admin/index.php",
      "dest": "/api/admin.php"
    },
    {
      "src": "/admin/?",
      "dest": "/api/admin.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
